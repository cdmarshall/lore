# ============================================================
# Lore .gitignore
# Personal user data is gitignored. The repo only commits the
# agent logic, workflows, playbooks, and templates.
# ============================================================

# --- Personal context (the master user profile) ---
/context.md

# --- Email triage config (personal sender lists, etc.) ---
/email-config.md

# --- Email triage processed-IDs tracking (append-only) ---
/inbox/.email-processed

# --- Personal team & stakeholder profiles ---
/team/*.md
/stakeholders/*.md

# --- Inbox: action items, working documents ---
/inbox/*.md
/inbox/documents/*
!/inbox/documents/.gitkeep

# --- Outbox: generated outputs (talk tracks, prep docs, exports) ---
/outbox/*
!/outbox/.gitkeep

# --- Decision log (personal decisions) ---
/decisions/log.md

# --- Weekly reviews (personal reflections) ---
/weekly-reviews/*.md

# --- Performance reviews (personal to each individual) ---
/reviews/*
!/reviews/.gitkeep

# --- Personal meeting history ---
/meetings/notes/*
!/meetings/notes/.gitkeep
/meetings/transcripts/*
!/meetings/transcripts/.gitkeep

# --- Strategy docs (user-specific) ---
/strategy/*.md

# --- Personal artifacts (binary docs, almost always personal) ---
*.xlsx
*.xls
*.xlsm
*.docx
*.doc
*.pptx
*.ppt
*.pdf
*.csv
*.tsv
.~lock*

# --- Secrets ---
.secrets/
*.token
*.key

# --- Machine-local agent settings ---
.claude/settings.local.json

# --- Generated artifacts (HTML widgets created by the agent) ---
/workflows/*.html
/inbox/*.html
/outbox/*.html

# --- Working files (commit message drafts, etc.) ---
/COMMIT_MSG.txt

# --- System ---
.DS_Store
Thumbs.db
__pycache__/
*.pyc
node_modules/
